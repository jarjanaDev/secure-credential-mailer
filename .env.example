SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=credentials@company.com
SMTP_PASSWORD=your_password
SENDER_NAME=IT Operations

# Seconds to wait between Part 1 and Part 2 emails (compliance requirement)
SPLIT_DELAY_SECONDS=30

# Days until temporary credential expires
CREDENTIAL_EXPIRY_DAYS=7

# SQLite audit database path
AUDIT_DB=audit/audit.db

# Fernet encryption key — generate with: python mailer.py --keygen
# REQUIRED: set this before sending any credentials
FERNET_KEY=
